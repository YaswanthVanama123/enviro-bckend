# ============================================================================
# ENVIRONMENT & SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=5000

# ⚠️ IMPORTANT: Update this AFTER deploying to Render
# Example: https://enviromaster-backend.onrender.com (NO trailing slash)
SERVER_URL=https://your-app-name.onrender.com

# ============================================================================
# DATABASE CONFIGURATION (MongoDB Atlas)
# ============================================================================
MONGO_URI=mongodb+srv://vanamayaswanth1_db_user:NzvLPS9c2KO02tDz@cluster0.f1kzy9b.mongodb.net/enviro_master?retryWrites=true&w=majority
MONGO_DB=enviro_master

# ============================================================================
# PDF SERVICE CONFIGURATION
# ============================================================================
# ⚠️ IMPORTANT: Do NOT include /pdf at the end! The code adds the path automatically.
# CORRECT: http://45.55.208.199:3000
# WRONG: http://45.55.208.199:3000/pdf (causes double /pdf/pdf/ in URL)
PDF_REMOTE_BASE=http://45.55.208.199:3000
PDF_MAX_BODY_MB=5
PDF_REMOTE_TIMEOUT_MS=90000

# ============================================================================
# ZOHO BIGIN INTEGRATION
# ============================================================================
# Client credentials from Zoho API Console (US: api-console.zoho.com  /  India: api-console.zoho.in)
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret

# Data center URLs — use .com for US, .in for India, .eu for Europe
# US account (bigin.zoho.com):
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BIGIN_API_URL=https://www.zohoapis.com/bigin/v2
ZOHO_CRM_API_URL=https://www.zohoapis.com/crm/v3
# India account (bigin.zoho.in): change above three lines to accounts.zoho.in / zohoapis.in

# ⚠️ IMPORTANT: Update this AFTER deploying to Render
# Example: https://enviromaster-backend.onrender.com/oauth/callback
# This MUST match the redirect URI in Zoho API Console
ZOHO_REDIRECT_URI=http://localhost:5000/oauth/callback

# Zoho refresh token (will be regenerated after OAuth flow on production)
# Current token is for development - regenerate in production by visiting:
# https://your-app-name.onrender.com/oauth/zoho/auth
ZOHO_REFRESH_TOKEN=1000.8d0321c0d20a3ad9510702f16f4ed005.2b87fb7ed88fa12be4df88e02548c16b

# ============================================================================
# EMAIL CONFIGURATION (SMTP)
# ============================================================================
EMAIL_HOST=enviromasternva.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=hvanama@enviromasternva.com
EMAIL_PASSWORD=Satyavani@123
EMAIL_FROM_NAME=EnviroMaster NVA
EMAIL_FROM_ADDRESS=hvanama@enviromasternva.com

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# JWT Secret - Strong random string for token signing
JWT_SECRET=ecb3d1020938632c45709d08c96f478f9887e93e42395e1fd9be81c0eac72d00e00c0b78ba29691304cd14eaee41edeecd55218463f27e7217a25e891e14fe2a
JWT_EXPIRES_IN=7d

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# ⚠️ IMPORTANT: Update this AFTER deploying frontend to Render
# Example: https://enviromaster-frontend.onrender.com
# Multiple origins: https://frontend1.com,https://frontend2.com
# For local development, also include: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
#
# BEFORE DEPLOYING TO RENDER:
# 1. ✅ MongoDB Atlas - Already configured correctly
# 2. ✅ Email credentials - Already configured correctly
# 3. ✅ Zoho credentials - Already configured correctly
# 4. ✅ JWT_SECRET - Already generated (strong 128-char secret)
#
# AFTER DEPLOYING TO RENDER (Update these in Render Dashboard):
# 1. ⚠️ SERVER_URL → Set to your Render backend URL
#    Example: https://enviromaster-backend.onrender.com
#
# 2. ⚠️ ZOHO_REDIRECT_URI → Set to your Render backend OAuth callback
#    Example: https://enviromaster-backend.onrender.com/oauth/callback
#    IMPORTANT: Also update this in Zoho API Console!
#
# 3. ⚠️ ALLOWED_ORIGINS → Set to your Render frontend URL
#    Example: https://enviromaster-frontend.onrender.com
#    Can include multiple: https://frontend.onrender.com,https://www.yourdomain.com
#
# 4. 🔄 Complete OAuth flow to regenerate ZOHO_REFRESH_TOKEN:
#    Visit: https://your-backend.onrender.com/oauth/zoho/auth
#
# ============================================================================
